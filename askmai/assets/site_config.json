{
  "sites": {
    "chatgpt": {
      "id": "chatgpt",
      "urlPattern": "^https://chat\\.openai\\.com",
      "inputXPath": "//div[@id='prompt-textarea']",
      "submitXPath": "//button[@data-testid='send-button']",
      "displayName": "ChatGPT",
      "isDisplay": true,
      "viewportTop": 0,
      "viewportBottom": 0,
      "viewportLeft": 0,
      "viewportRight": 0
    },
