    },
    "gemini": {
      "urlPattern": "^https://gemini\\.google\\.com",
      "inputXPath": "//textarea[@aria-label='Message Gemini']",
      "submitXPath": "//button[@aria-label='Send']",
      "displayName": "Google Gemini"
    },
    "doubao": {
      "urlPattern": "^https://www\\.doubao\\.com",
      "inputXPath": "//textarea[@placeholder='输入你的问题...']",
